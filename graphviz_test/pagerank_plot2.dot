// pagerank_plot2
digraph {
	0 [label=0]
	1 [label=1]
	2 [label=2]
	3 [label=3]
	4 [label=4]
	5 [label=5]
	6 [label=6]
	0 -> 1 [label=0.5 fontcolor=red]
	0 -> 5 [label=0.5 fontcolor=red]
	1 -> 2 [label=1.0 fontcolor=red]
	2 -> 0 [label=0.5 fontcolor=red]
	2 -> 3 [label=0.5 fontcolor=red]
	3 -> 0 [label=1.0 fontcolor=red]
	4 -> 2 [label=1.0 fontcolor=red]
	5 -> 5 [label=1.0 fontcolor=red]
	6 -> 6 [label=1.0 fontcolor=red]
}
